{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "tenantId": {
            "type": "string",
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Azure Active Directory tenant ID that should be used for authenticating requests to the key vault. Get it by using Get-AzSubscription cmdlet."
            }
        }
    },
    "variables": {
        "identityName": "RegisterAppCredentialsUserIdentity",
        "roleDefinitionGUID": "[guid(subscription().id, resourceGroup().name, '/providers/Microsoft.Authorization/roleDefinitions/', 'create-application')]",
        "roleGUID": "[guid(subscription().id, resourceGroup().name, 'RegisterAppCredentialsUserIdentity')]"
    },
    "resources": [
        {
            "name": "[variables('identityName')]",
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
            "apiVersion": "2023-01-31",
            "location": "[resourceGroup().location]"
        },
        {
            "name": "[variables('roleGUID')]",
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "dependsOn": [
                "[variables('identityName')]"
            ],
            "properties": {
                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', '8e3af657-a8ff-443c-a75c-2fe8c4bcb635')]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "name": "AddMSGraphPermissions",
            "type": "Microsoft.Resources/deploymentScripts",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[variables('identityName')]"
            ],
            "kind": "AzurePowerShell",
            "apiVersion": "2020-10-01",
            "identity": {
                "type": "userAssigned",
                "userAssignedIdentities": {
                    "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.ManagedIdentity/userAssignedIdentities/', variables('identityName'))]": {}
                }
            },
            "properties": {
                "forceUpdateTag": "1",
                "azPowerShellVersion": "11.4",
                "timeout": "PT30M",
                "environmentVariables": [
                  {
                    "name": "msiObjectId",
                    "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName'))).principalId]"
                  }
                ],
                "scriptContent": "
                    # Get-InstalledModule -Name Az* | Update-Module

                    Update-Module -Name Az.Accounts -Force
                    # Import-Module -Name Az.Accounts -Force

                    # Import-Module -Name PSCloudShellUtility -Force

                    Install-Module -Name Az -AllowClobber -Force

                    . $profile

                    Import-Module -Name Az -Force

                    $msiObjectId = "9952d6f7-1d5b-4775-8862-90345fbb2b52"
                    # Windows Azure Active Directory
                    $GraphAppId = '00000002-0000-0000-c000-000000000000'
                    $GraphServicePrincipal = Get-AzureADServicePrincipal `
                            -Filter \"appId eq '$GraphAppId'\"

                    $PermissionName = 'Application.ReadWrite.OwnedBy'
                    $AppRole = $GraphServicePrincipal.AppRoles  `
                           | Where-Object {$_.Value -eq $PermissionName `
                           -and $_.AllowedMemberTypes -contains  'Application'}

                    New-AzureAdServiceAppRoleAssignment `
                        -ObjectId $msiObjectId `
                        -PrincipalId $msiObjectId  `
                        -ResourceId $GraphServicePrincipal.ObjectId `
                        -Id $AppRole.Id
                ",
                "cleanupPreference": "OnSuccess",
                "retentionInterval": "P1D"
            }
        },
        {
            "name": "RegisterAppCredentials",
            "type": "Microsoft.Resources/deploymentScripts",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "AddMSGraphPermissions"
            ],
            "kind": "AzureCLI",
            "apiVersion": "2020-10-01",
            "identity": {
                "type": "userAssigned",
                "userAssignedIdentities": {
                    "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.ManagedIdentity/userAssignedIdentities/', variables('identityName'))]": {}
                }
            },
            "properties": {
                "forceUpdateTag": "1",
                "azCliVersion": "2.54.0",
                "timeout": "PT30M",
                "scriptContent": "az ad app create --display-name cloudbeat-test",
                "cleanupPreference": "OnSuccess",
                "retentionInterval": "P1D"
            }
        }
    ]
}
