{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "tenantId": {
            "type": "string",
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Azure Active Directory tenant ID that should be used for authenticating requests to the key vault. Get it by using Get-AzSubscription cmdlet."
            }
        }
    },
    "variables": {
        "identityName": "RegisterAppCredentialsUserIdentity",
        "roleDefinitionGUID": "[guid(subscription().id, resourceGroup().name, '/providers/Microsoft.Authorization/roleDefinitions/', 'create-application')]",
        "roleGUID": "[guid(subscription().id, resourceGroup().name, 'RegisterAppCredentialsUserIdentity')]"
    },
    "resources": [
        {
            "type": "Microsoft.Authorization/roleDefinitions",
            "apiVersion": "2022-04-01",
            "name": "[variables('roleDefinitionGUID')]",
            "properties": {
                "assignableScopes": [
                    "[concat('/subscriptions/', subscription().subscriptionId)]",
                    "[concat('/subscriptions/', subscription().subscriptionId, '/resourcegroups/', resourceGroup().name)]"
                ],
                "description": "Permissions to register application as owners",
                "permissions": [
                    {
                        "actions": [
                            "microsoft.directory/applications/*/write"
                        ],
                        "dataActions": [],
                        "notActions": [],
                        "notDataActions": []
                    }
                ],
                "roleName": "Register Application",
                "type": "CustomRole"
            }
        },
        {
            "name": "[variables('identityName')]",
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
            "apiVersion": "2023-01-31",
            "location": "[resourceGroup().location]"
        },
        {
            "name": "[variables('roleGUID')]",
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "dependsOn": ["RegisterAppCredentialsUserIdentity"],
            "properties": {
                "roleDefinitionId": "[variables('roleDefinitionGUID')]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('identityName')), '2018-11-30').principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "name": "RegisterAppCredentials",
            "type": "Microsoft.Resources/deploymentScripts",
            "location": "[resourceGroup().location]",
            "dependsOn": ["[variables('roleGUID')]"],
            "kind": "AzureCLI",
            "apiVersion": "2020-10-01",
            "identity": {
                "type": "userAssigned",
                "userAssignedIdentities": {
                    "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.ManagedIdentity/userAssignedIdentities/', variables('identityName'))]": {}
                }
            },
            "properties": {
                "forceUpdateTag": "1",
                "azCliVersion": "2.54.0",
                "timeout": "PT30M",
                "scriptContent": "az ad app create --display-name cloudbeat-test",
                "cleanupPreference": "OnSuccess",
                "retentionInterval": "P1D"
            }
        }
    ]
}
